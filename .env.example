# ════════════════════════════════════════════════════════
#  Elevitte AI – Environment Variables
#  Copy this file to .env  →  cp .env.example .env
#  NEVER commit .env to Git. It is in .gitignore.
# ════════════════════════════════════════════════════════

# ── Your domain (no trailing slash)
SITE_URL=https://elevitte.ai

# ── Server port (for standalone server.js)
PORT=3000

# ── Razorpay API Keys
#    Get from: https://dashboard.razorpay.com → Settings → API Keys
#    Use TEST keys during development, switch to LIVE keys for production

RAZORPAY_KEY_ID=xxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxx

# ── Email notifications (optional – choose one)
# Resend (recommended): https://resend.com
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXX

# ── Google Sheets logging (optional)
#    Deploy a Google Apps Script as a Web App and paste the URL here
GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec
