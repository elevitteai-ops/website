{
  "version": 2,
  "name": "elevitte-ai",
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "regions": ["bom1"],
  "env": {
    "SITE_URL": "https://elevitte.ai"
  }
}
